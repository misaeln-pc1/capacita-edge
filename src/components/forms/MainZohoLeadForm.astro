---
const { form } = Astro.props;
---

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<style>
  .zoho-v18-form {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .zoho-v18-form label {
    display: block;
    font-size: 11px;
    font-weight: 800;
    color: #475569;
    margin-bottom: 4px;
    margin-top: 8px;
    text-transform: uppercase;
  }

  .zoho-v18-form input[type="text"],
  .zoho-v18-form textarea {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid #cbd5e1;
    border-radius: 8px;
    font-size: 14px;
    background: #ffffff;
    box-sizing: border-box;
    font-family: inherit;
    transition: border-color 0.3s;
  }

  .zoho-v18-form input[type="text"]:focus,
  .zoho-v18-form textarea:focus {
    outline: none;
    border-color: #004A99;
  }

  .zoho-v18-form textarea {
    min-height: 72px;
    resize: vertical;
  }

  .zoho-v18-form em {
    font-style: normal;
    color: #ef4444;
    margin-left: 2px;
  }

  .btn-submit-v18 {
    width: 100%;
    background: var(--hero-accent, #ff9800);
    color: #fff;
    padding: 14px;
    border: none;
    border-radius: 50px;
    font-size: 16px;
    font-weight: 900;
    cursor: pointer;
    margin-top: 15px;
    text-transform: uppercase;
    transition: 0.3s;
    box-shadow: 0 8px 20px rgba(255, 152, 0, 0.3);
  }

  .btn-submit-v18:hover {
    filter: brightness(0.95);
    transform: translateY(-2px);
  }
</style>

<form
  action={form.action}
  name="form"
  id="zoho-native-form"
  method="POST"
  accept-charset="UTF-8"
  enctype="multipart/form-data"
  class="zoho-v18-form"
>
  <input type="hidden" name="zf_referrer_name" id="zf_referrer_name" value="" />
  <input type="hidden" name="zf_redirect_url" id="zf_redirect_url" value="" />
  <input type="hidden" name="zc_gad" id="zc_gad" value="" />

  
  <div style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;" aria-hidden="true">
  <label for="hp_field">No llenar</label>
  <input id="hp_field" type="text" name="hp_field" value="" tabindex="-1" autocomplete="off" />
</div>

  <input type="hidden" name="SingleLine14" id="utm_source" value="" />
  <input type="hidden" name="SingleLine18" id="utm_medium" value="" />
  <input type="hidden" name="SingleLine13" id="utm_campaign" value="" />
  <input type="hidden" name="SingleLine17" id="utm_term" value="" />
  <input type="hidden" name="SingleLine16" id="utm_content" value="" />
  <input type="hidden" name="SingleLine11" id="utm_id" value="" />
  <input type="hidden" name="SingleLine5" id="gclid" value="" />
  <input type="hidden" name="SingleLine6" id="gbraid" value="" />
  <input type="hidden" name="SingleLine12" id="wbraid" value="" />
  <input type="hidden" name="SingleLine8" id="fbclid" value="" />
  <input type="hidden" name="SingleLine7" id="msclkid" value="" />
  <input type="hidden" name="SingleLine9" id="li_fat_id" value="" />
  <input type="hidden" name="SingleLine10" id="ttclid" value="" />

  <input type="hidden" name="SingleLine24" id="client_id" value="" />
  <input type="hidden" name="SingleLine25" id="session_id" value="" />
  <input type="hidden" name="SingleLine23" id="lead_event_id" value="" />

<input type="hidden" name="SingleLine3" id="landing_fuente" value={form.landingFuente ?? ''} />
<input type="hidden" name="SingleLine2" id="curso_interesado" value={form.cursoInteresado ?? ''} />
<input type="hidden" name="SingleLine1" id="tipo_modalidad" value={form.tipoModalidad ?? ''} />
<input type="hidden" name="SingleLine15" id="landing_code" value={form.landingCode ?? ''} />

  <input type="hidden" name="Website" id="landing_url" value="" />
  <input type="hidden" name="Website1" id="referente" value="" />
  <input type="hidden" name="SingleLine19" id="dispositivo" value="" />
  <input type="hidden" name="SingleLine20" id="user_agent" value="" />
  <input type="hidden" name="SingleLine21" id="page_title" value="" />
  <input type="hidden" name="SingleLine22" id="user_language" value="" />

  <input type="hidden" name="SingleLine26" id="ciudad_user" value="" />
  <input type="hidden" name="SingleLine27" id="pais_user" value="" />
  <input type="hidden" name="SingleLine28" id="timezone" value="" />
  <input type="hidden" name="SingleLine29" id="tiempo_pagina" value="" />

  <input type="hidden" name="DateTime_date" id="capture_date" value="" />
  <input type="hidden" name="DateTime_hours" id="capture_hours" value="" />
  <input type="hidden" name="DateTime_minutes" id="capture_minutes" value="" />
  <input type="hidden" name="DateTime_meridiem" id="capture_meridiem" value="" />

  <label for="lead_name">¿Cómo te llamas?<em>*</em></label>
  <input
    id="lead_name"
    type="text"
    name="SingleLine"
    maxlength="255"
    placeholder="Tu nombre"
    required
  />

  <label for="lead_email">Tu mejor Email:<em>*</em></label>
  <input
    id="lead_email"
    type="text"
    maxlength="255"
    name="Email"
    placeholder="tu@correo.cl"
    required
  />

  <label for="lead_phone">WhatsApp:<em>*</em></label>
  <input
    id="lead_phone"
    type="text"
    name="PhoneNumber_countrycode"
    maxlength="20"
    placeholder="9 1234 5678"
    required
  />

  <label for="lead_notes">¿Dudas?</label>
  <textarea
    id="lead_notes"
    name="MultiLine"
    placeholder="Horarios, pagos, etc..."
    maxlength="1000"
  ></textarea>

<div
  class="cf-turnstile"
  data-sitekey={form.turnstileSiteKey}
  data-theme="light"
  data-appearance="interaction-only"
  style="margin-top:16px;margin-bottom:12px;"
></div>

  <button type="submit" class="btn-submit-v18">
    {form.submitText ?? 'Regístrate'}
  </button>
</form>
<script is:inline>
  (() => {
    const formEl = document.getElementById('zoho-native-form');
    if (!formEl) return;

    const setWebsiteFields = () => {
      const isLocal =
        window.location.hostname === 'localhost' ||
        window.location.hostname === '127.0.0.1';

      const landingUrlInput = document.getElementById('landing_url');
      const referenteInput = document.getElementById('referente');

      if (isLocal) {
        // En local usa URLs válidas para pasar la validación de Zoho Forms
        if (landingUrlInput) landingUrlInput.value = 'https://capacita.cl';
        if (referenteInput) referenteInput.value = 'https://capacita.cl';
        return;
      }

      if (landingUrlInput) {
        landingUrlInput.value = window.location.href || 'https://capacita.cl';
      }

      if (referenteInput) {
        const ref = document.referrer || '';
        referenteInput.value = ref ? ref : 'https://capacita.cl';
      }
    };

    // Para que al inspeccionar ya se vean correctos
    setWebsiteFields();

    // Y para asegurar que ningún otro script los deje malos antes del envío
    formEl.addEventListener('submit', () => {
      setWebsiteFields();
    });
  })();
</script>