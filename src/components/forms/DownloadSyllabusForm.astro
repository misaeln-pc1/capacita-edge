---
const { form } = Astro.props;
---

<style>
  .zoho-inline-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    box-sizing: border-box;
  }

  .hp-wrap {
    position: absolute !important;
    left: -9999px !important;
    top: auto !important;
    width: 1px !important;
    height: 1px !important;
    overflow: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  .dl-input {
    width: 100%;
    background: #ffffff;
    border: 1px solid #cbd5e1;
    padding: 12px 15px;
    border-radius: 10px;
    font-size: 14px;
    color: #334155;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
    font-family: inherit;
  }

  .dl-input::placeholder {
    color: #94a3b8;
  }

  .dl-input:focus {
    border-color: #f2994a;
    box-shadow: 0 0 0 3px rgba(242, 153, 74, 0.12);
  }

  .dl-btn {
    width: 100%;
    background: #f2994a;
    color: #ffffff;
    border: none;
    padding: 13px 16px;
    border-radius: 10px;
    cursor: pointer;
    text-transform: uppercase;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.2px;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    box-shadow: 0 8px 18px rgba(242, 153, 74, 0.22);
    font-family: inherit;
  }

  .dl-btn:hover {
    background: #ea8d3c;
    transform: translateY(-1px);
    box-shadow: 0 10px 22px rgba(242, 153, 74, 0.28);
  }

  .dl-btn:active {
    transform: translateY(0);
  }
</style>

<form
  action={form.action}
  name="form_dl"
  id="form_dl"
  method="POST"
  accept-charset="UTF-8"
  enctype="multipart/form-data"
  class="zoho-inline-form"
>
  <input type="hidden" name="zf_referrer_name" id="dl_zf_referrer_name" value="" />
  <input type="hidden" name="zf_redirect_url" id="dl_zf_redirect_url" value="" />
  <input type="hidden" name="zc_gad" id="dl_zc_gad" value="" />

  <input
    class="dl-input"
    type="email"
    maxlength="255"
    name="Email"
    value=""
    placeholder="tu@correo.cl"
    required
  />

  <div class="hp-wrap" aria-hidden="true">
    <input
      type="text"
      name="hp_field"
      tabindex="-1"
      autocomplete="off"
    />
  </div>

  <div
    class="cf-turnstile"
    data-sitekey={form.turnstileSiteKey}
    data-theme="light"
    data-appearance="interaction-only"
    style="margin-top:16px;margin-bottom:12px;"
  ></div>

  <button class="dl-btn" type="submit">{form.buttonText}</button>
</form>

<script>
  const dlRef = document.getElementById('dl_zf_referrer_name');
  const dlRedirect = document.getElementById('dl_zf_redirect_url');

  if (dlRef) dlRef.value = window.location.href;
  if (dlRedirect) dlRedirect.value = window.location.href;
</script>