---
import DownloadSyllabusForm from '../forms/DownloadSyllabusForm.astro';

const { data, downloadForm } = Astro.props;
const modules = data.modules ?? [];
---

<section class="cp-syllabus-fixed" id="temario">
  <style>
    .cp-syllabus-fixed {
      width: 100%;
      max-width: 980px;
      margin: 70px auto;
      padding: 0 20px;
      font-family: 'Segoe UI', Roboto, sans-serif !important;
      box-sizing: border-box;
      scroll-margin-top: 100px;
    }

    .syllabus-header-v9 {
      text-align: center;
      margin-bottom: 34px;
    }

    .syllabus-header-v9 h2 {
      color: #004a99;
      font-size: clamp(34px, 5vw, 56px);
      font-weight: 900;
      margin: 0 0 14px 0;
      line-height: 1.08;
    }

    .syllabus-header-v9 p {
      color: #64748b;
      font-size: 18px;
      margin: 0;
      line-height: 1.5;
    }

    .syllabus-download-bar {
      background: #f1f5f9;
      border-left: 5px solid #f2994a;
      border-radius: 18px;
      margin: 0 auto 36px auto;
      padding: 24px 28px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 26px;
      box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
      box-sizing: border-box;
    }

    .dl-text {
      flex: 1.2;
      min-width: 240px;
    }

    .dl-text h3 {
      margin: 0 0 6px 0;
      color: #004a99;
      font-size: 20px;
      font-weight: 800;
      line-height: 1.2;
    }

    .dl-text p {
      margin: 0;
      color: #64748b;
      font-size: 15px;
      line-height: 1.45;
    }

    .dl-form-wrapper {
      flex: 0 0 290px;
      max-width: 290px;
      width: 100%;
      box-sizing: border-box;
    }

    .syllabus-list-v9 {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .syllabus-item-v9 {
      background: #ffffff;
      border-radius: 24px;
      box-shadow: 0 10px 28px rgba(0, 74, 153, 0.08);
      border: 2px solid transparent;
      overflow: hidden;
      transition: border-color 0.25s ease, box-shadow 0.25s ease;
    }

    .syllabus-q-v9 {
      padding: 26px 34px;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 20px;
    }

    .syllabus-q-v9 h3 {
      margin: 0;
      font-size: 19px;
      color: #004a99;
      font-weight: 800;
      line-height: 1.2;
    }

    .syllabus-plus-v9 {
      flex: 0 0 auto;
      font-size: 34px;
      line-height: 1;
      color: #d4af37;
      font-weight: 500;
      transition: transform 0.25s ease, color 0.25s ease;
    }

    .syllabus-a-v9 {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      padding: 0 34px;
      transition: max-height 0.35s ease, opacity 0.25s ease, padding 0.25s ease;
    }

    .syllabus-grid-v9 {
      list-style: none;
      padding: 0 0 28px 0;
      margin: 0;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px 20px;
    }

    .syllabus-grid-v9 li {
      font-size: 15px;
      color: #475569;
      display: flex;
      align-items: flex-start;
      line-height: 1.45;
    }

    .syllabus-grid-v9 li::before {
      content: "✓";
      color: #d4af37;
      font-weight: 900;
      margin-right: 10px;
      flex: 0 0 auto;
    }

    .syllabus-empty-v9 {
      padding: 0 0 28px 0;
      color: #64748b;
      font-size: 15px;
      line-height: 1.45;
    }

    .syllabus-item-v9.active {
      border-color: #004a99;
      box-shadow: 0 14px 32px rgba(0, 74, 153, 0.12);
    }

    .syllabus-item-v9.active .syllabus-q-v9 {
      background: #004a99;
    }

    .syllabus-item-v9.active .syllabus-q-v9 h3 {
      color: #ffffff;
    }

    .syllabus-item-v9.active .syllabus-plus-v9 {
      color: #ffffff;
      transform: rotate(45deg);
    }

    .syllabus-item-v9.active .syllabus-a-v9 {
      max-height: 900px;
      opacity: 1;
      padding-top: 18px;
    }

    @media (max-width: 768px) {
      .cp-syllabus-fixed {
        margin: 55px auto;
        padding: 0 16px;
      }

      .syllabus-header-v9 h2 {
        font-size: 38px;
      }

      .syllabus-header-v9 p {
        font-size: 16px;
      }

      .syllabus-download-bar {
        flex-direction: column;
        align-items: stretch;
        text-align: left;
        padding: 22px 20px;
      }

      .dl-form-wrapper {
        max-width: 100%;
        flex-basis: auto;
      }

      .syllabus-q-v9 {
        padding: 22px 22px;
      }

      .syllabus-a-v9 {
        padding: 0 22px;
      }

      .syllabus-grid-v9 {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="syllabus-header-v9">
    <h2>{data.title}</h2>
    <p>{data.description}</p>
  </div>

  <div class="syllabus-download-bar">
    <div class="dl-text">
      <h3>{downloadForm.title}</h3>
      <p>{downloadForm.description}</p>
    </div>

    <div class="dl-form-wrapper">
      <DownloadSyllabusForm form={downloadForm} />
    </div>
  </div>

  <div class="syllabus-list-v9">
    {modules.map((module) => (
      <div class="syllabus-item-v9">
        <div class="syllabus-q-v9">
          <h3>{module.title}</h3>
          <span class="syllabus-plus-v9">+</span>
        </div>

        <div class="syllabus-a-v9">
          {(module.items ?? []).length > 0 ? (
            <ul class="syllabus-grid-v9">
              {module.items.map((item) => <li>{item}</li>)}
            </ul>
          ) : (
            <div class="syllabus-empty-v9">
              Contenido detallado próximamente.
            </div>
          )}
        </div>
      </div>
    ))}
  </div>

  <script is:inline>
    (() => {
      const section = document.querySelector('#temario');
      if (!section) return;

      const triggers = section.querySelectorAll('.syllabus-q-v9');

      triggers.forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const parent = trigger.parentElement;
          const allItems = section.querySelectorAll('.syllabus-item-v9');

          allItems.forEach((item) => {
            if (item !== parent) item.classList.remove('active');
          });

          parent.classList.toggle('active');
        });
      });
    })();
  </script>
</section>