---
const { data } = Astro.props;
const items = data.items ?? [];

const getImageSrc = (img) => {
  if (!img) return '';
  if (typeof img === 'string') return img;
  return img.src ?? '';
};
---

<section class="cp-testimonials-v2" id="testimonios">
  <style>
    .cp-testimonials-v2 {
      background: #004a99;
      color: #ffffff;
      padding: 70px 20px 80px;
      font-family: 'Segoe UI', Roboto, sans-serif !important;
    }

    .cp-testimonials-wrap {
      max-width: 1180px;
      margin: 0 auto;
    }

    .cp-testimonials-head {
      text-align: center;
      margin-bottom: 46px;
    }

    .cp-testimonials-kicker {
      display: inline-block;
      margin-bottom: 16px;
      color: #f2c94c;
      font-size: 14px;
      font-weight: 800;
      letter-spacing: 3px;
      text-transform: uppercase;
    }

    .cp-testimonials-head h2 {
      margin: 0 0 18px 0;
      color: #ffffff;
      font-size: clamp(34px, 5vw, 58px);
      line-height: 1.08;
      font-weight: 900;
    }

    .cp-testimonials-head p {
      margin: 0 auto;
      max-width: 760px;
      color: rgba(255, 255, 255, 0.9);
      font-size: 18px;
      line-height: 1.45;
    }

    .cp-testimonials-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 34px;
    }

    @media (min-width: 900px) {
      .cp-testimonials-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .cp-testimonial-card {
      text-align: center;
      padding: 0 18px;
    }

    .cp-testimonial-photo-wrap {
      display: flex;
      justify-content: center;
      margin-bottom: 22px;
    }

    .cp-testimonial-photo {
      width: 230px;
      height: 340px;
      object-fit: cover;
      border-radius: 999px;
      border: 3px solid #d4af37;
      display: block;
      background: rgba(255, 255, 255, 0.08);
      box-shadow: 0 14px 30px rgba(0, 0, 0, 0.18);
    }

    .cp-testimonial-name {
      margin: 0 0 6px 0;
      color: #f2c94c;
      font-size: 22px;
      font-weight: 900;
      line-height: 1.1;
    }

    .cp-testimonial-role {
      margin: 0 0 20px 0;
      color: rgba(255, 255, 255, 0.92);
      font-size: 14px;
      font-weight: 800;
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }

    .cp-testimonial-quote {
      margin: 0 auto;
      max-width: 310px;
      color: rgba(255, 255, 255, 0.95);
      font-size: 15px;
      line-height: 1.65;
      font-style: italic;
    }
  </style>

  <div class="cp-testimonials-wrap">
    <div class="cp-testimonials-head">
      {data.kicker && <div class="cp-testimonials-kicker">{data.kicker}</div>}
      <h2>{data.title}</h2>
      {data.subtitle && <p>{data.subtitle}</p>}
    </div>

    <div class="cp-testimonials-grid">
      {items.map((item) => (
        <article class="cp-testimonial-card">
          <div class="cp-testimonial-photo-wrap">
            <img
              src={getImageSrc(item.image)}
              alt={item.name}
              class="cp-testimonial-photo"
              loading="lazy"
            />
          </div>

          <h3 class="cp-testimonial-name">{item.name}</h3>
          <div class="cp-testimonial-role">{item.role}</div>
          <p class="cp-testimonial-quote">"{item.quote}"</p>
        </article>
      ))}
    </div>
  </div>
</section>