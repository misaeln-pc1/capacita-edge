---
const { data } = Astro.props;
const items = data.items ?? [];

const getImageSrc = (img) => {
  if (!img) return '';
  if (typeof img === 'string') return img;
  return img.src ?? '';
};
---

<section class="cp-quality-seals-v2" id="sellos-calidad">
  <style>
    .cp-quality-seals-v2 {
      width: 100%;
      max-width: 1280px;
      margin: 70px auto 80px;
      padding: 0 20px;
      font-family: 'Segoe UI', Roboto, sans-serif !important;
      box-sizing: border-box;
      text-align: center;
    }

    .seals-head-v2 {
      margin-bottom: 42px;
    }

    .seals-head-v2 h2 {
      margin: 0 0 12px 0;
      color: #004A99;
      font-size: clamp(34px, 5vw, 56px);
      line-height: 1.08;
      font-weight: 900;
    }

    .seals-head-v2 p {
      margin: 0;
      color: #64748b;
      font-size: 18px;
      line-height: 1.45;
    }

    .seals-grid-v2 {
      display: grid;
      grid-template-columns: 1fr;
      gap: 34px;
      align-items: start;
    }

    @media (min-width: 900px) {
      .seals-grid-v2 {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .seal-card-v2 {
      padding: 0 18px;
    }

    .seal-image-wrap-v2 {
      height: 150px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 22px;
    }

    .seal-image-v2 {
      max-width: 100%;
      max-height: 135px;
      width: auto;
      height: auto;
      object-fit: contain;
      display: block;
    }

    .seal-title-v2 {
      margin: 0 0 14px 0;
      color: #16325c;
      font-size: 22px;
      font-weight: 900;
      line-height: 1.2;
    }

    .seal-desc-v2 {
      margin: 0 auto;
      max-width: 320px;
      color: #475569;
      font-size: 17px;
      line-height: 1.6;
    }
  </style>

  <div class="seals-head-v2">
    <h2>{data.title}</h2>
    {data.subtitle && <p>{data.subtitle}</p>}
  </div>

  <div class="seals-grid-v2">
    {items.map((item) => (
      <article class="seal-card-v2">
        <div class="seal-image-wrap-v2">
          <img
            src={getImageSrc(item.image)}
            alt={item.title}
            class="seal-image-v2"
            loading="lazy"
          />
        </div>

        <h3 class="seal-title-v2">{item.title}</h3>
        <p class="seal-desc-v2">{item.description}</p>
      </article>
    ))}
  </div>
</section>