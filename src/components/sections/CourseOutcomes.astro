---
const { data } = Astro.props;
const primaryItems = data.primaryItems ?? [];
const secondaryItems = data.secondaryItems ?? [];
---

<section class="cp-course-outcomes" id="que-te-llevas">
  <style>
    .cp-course-outcomes {
      width: 100%;
      max-width: 1180px;
      margin: 0 auto 24px;
      padding: 0 20px;
      font-family: 'Segoe UI', Roboto, sans-serif !important;
      box-sizing: border-box;
    }

    .outcomes-card {
  background: #eef6ff;
  border: 1px solid #dbeafe;
  border-radius: 24px;
  box-shadow: 0 14px 30px rgba(15, 23, 42, 0.05);
  padding: 30px;
}

    .outcomes-head {
      margin-bottom: 24px;
    }

    .outcomes-head h2 {
      margin: 0 0 10px 0;
      color: #004A99;
      font-size: clamp(28px, 4vw, 44px);
      line-height: 1.08;
      font-weight: 900;
    }

    .outcomes-head p {
      margin: 0;
      color: #64748b;
      font-size: 17px;
      line-height: 1.45;
      max-width: 760px;
    }

    .outcomes-grid {
      display: grid;
      grid-template-columns: 1.05fr 0.95fr;
      gap: 20px;
    }

    .outcomes-panel {
      border: 1px solid #e2e8f0;
      border-radius: 22px;
      padding: 24px;
      background: #ffffff;
    }

    .outcomes-panel h3 {
      margin: 0 0 14px 0;
      color: #004A99;
      font-size: 24px;
      line-height: 1.2;
      font-weight: 800;
    }

    .outcomes-list {
      display: grid;
      gap: 12px;
      padding: 0;
      margin: 0;
      list-style: none;
    }

    .outcomes-list li {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      color: #243b53;
      font-size: 17px;
      line-height: 1.45;
    }

    .outcomes-list li::before {
      content: "✓";
      color: #d4af37;
      font-weight: 900;
      flex: 0 0 auto;
    }

    @media (max-width: 980px) {
      .outcomes-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      .cp-course-outcomes {
        padding: 0 16px;
      }

      .outcomes-card {
        padding: 22px;
      }

      .outcomes-panel {
        padding: 20px;
      }
    }
  </style>

  <div class="outcomes-card">
    <div class="outcomes-head">
      <h2>{data.title}</h2>
      {data.subtitle && <p>{data.subtitle}</p>}
    </div>

    <div class="outcomes-grid">
      <div class="outcomes-panel">
        <h3>{data.primaryTitle}</h3>
        <ul class="outcomes-list">
          {primaryItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <div class="outcomes-panel">
        <h3>{data.secondaryTitle}</h3>
        <ul class="outcomes-list">
          {secondaryItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>