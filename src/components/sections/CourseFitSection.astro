---
const { data } = Astro.props;
const yesItems = data.yesItems ?? [];
const noItems = data.noItems ?? [];
---

<section class="cp-course-fit" id="perfil-recomendado-curso">
  <style>
    .cp-course-fit {
      width: 100%;
      max-width: 1180px;
      margin: 0 auto 24px;
      padding: 0 20px;
      font-family: 'Segoe UI', Roboto, sans-serif !important;
      box-sizing: border-box;
    }

    .fit-card {
      background: #f8fbff;
      border: 1px solid #dbeafe;
      border-radius: 24px;
      box-shadow: 0 14px 30px rgba(15, 23, 42, 0.05);
      padding: 30px;
    }

    .fit-head {
      margin-bottom: 24px;
    }

    .fit-head h2 {
      margin: 0 0 10px 0;
      color: #004A99;
      font-size: clamp(28px, 4vw, 44px);
      line-height: 1.08;
      font-weight: 900;
    }

    .fit-head p {
      margin: 0;
      color: #64748b;
      font-size: 17px;
      line-height: 1.45;
      max-width: none;
    }

    .fit-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
    }

    .fit-panel {
      border-radius: 22px;
      padding: 24px;
      border: 1px solid #e2e8f0;
      background: #ffffff;
    }

    .fit-panel--yes {
      box-shadow: 0 10px 25px rgba(0, 74, 153, 0.06);
      border-color: #cfe0f5;
    }

    .fit-panel--no {
      background: #fffaf5;
      border-color: #fed7aa;
    }

    .fit-panel h3 {
      margin: 0 0 14px 0;
      font-size: 24px;
      color: #004A99;
      line-height: 1.2;
      font-weight: 800;
    }

    .fit-list {
      display: grid;
      gap: 12px;
      padding: 0;
      margin: 0;
      list-style: none;
    }

    .fit-list li {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      color: #243b53;
      font-size: 17px;
      line-height: 1.45;
    }

    .fit-list li::before {
      content: "✓";
      color: #d4af37;
      font-weight: 900;
      flex: 0 0 auto;
    }

    .fit-cta {
      margin-top: 18px;
      padding: 18px 20px;
      border-radius: 18px;
      background: #eff6ff;
      border: 1px solid #bfdbfe;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }

    .fit-cta strong {
      color: #004A99;
      font-size: 18px;
      line-height: 1.35;
    }

    .fit-cta a {
      background: #004A99;
      color: #fff;
      text-decoration: none;
      border-radius: 999px;
      padding: 12px 20px;
      font-weight: 800;
      line-height: 1.2;
      display: inline-block;
    }

    @media (max-width: 980px) {
      .fit-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 720px) {
      .cp-course-fit {
        padding: 0 16px;
      }

      .fit-card {
        padding: 22px;
      }

      .fit-panel {
        padding: 20px;
      }
    }
  </style>

  <div class="fit-card">
    <div class="fit-head">
      <h2>{data.title}</h2>
      {data.subtitle && <p>{data.subtitle}</p>}
    </div>

    <div class="fit-grid">
      <div class="fit-panel fit-panel--yes">
        <h3>{data.yesTitle}</h3>
        <ul class="fit-list">
          {yesItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <div class="fit-panel fit-panel--no">
        <h3>{data.noTitle}</h3>
        <ul class="fit-list">
          {noItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>

    <div class="fit-cta">
      <strong>{data.ctaText}</strong>
      <a href={data.ctaHref ?? '#registro'}>{data.ctaButtonText ?? 'Ir al registro'}</a>
    </div>
  </div>
</section>