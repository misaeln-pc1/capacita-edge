---
const { data } = Astro.props;
const sharedItems = data.sharedItems ?? [];
const pills = data.pills ?? [];
---

<section class="cp-quick-facts" id="ficha-rapida-curso">
  <style>
    .cp-quick-facts {
      width: 100%;
      max-width: 1180px;
      margin: 26px auto 24px;
      padding: 0 20px;
      font-family: 'Segoe UI', Roboto, sans-serif !important;
      box-sizing: border-box;
    }

    .quick-card {
      background: #ffffff;
      border: 1px solid #dbe4f0;
      border-top: 5px solid #004A99;
      border-radius: 24px;
      box-shadow: 0 14px 30px rgba(15, 23, 42, 0.05);
      padding: 30px;
    }

    .quick-head {
      margin-bottom: 22px;
    }

    .quick-head h2 {
      margin: 0 0 10px 0;
      color: #004A99;
      font-size: clamp(28px, 4vw, 44px);
      line-height: 1.08;
      font-weight: 900;
    }

    .quick-head p {
      margin: 0;
      color: #64748b;
      font-size: 17px;
      line-height: 1.45;
      max-width: none;
    }

    .quick-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }

    .quick-item {
      background: #f8fafc;
      border: 1px solid #e2e8f0;
      border-radius: 18px;
      padding: 18px 16px;
      min-height: 110px;
    }

    .quick-label {
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 1.1px;
      text-transform: uppercase;
      color: #64748b;
      margin-bottom: 10px;
    }

    .quick-value {
      color: #004A99;
      font-size: 22px;
      font-weight: 900;
      line-height: 1.15;
    }

    .quick-subvalue {
      display: block;
      margin-top: 6px;
      color: #64748b;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.35;
    }

    .quick-pills {
      margin-top: 20px;
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .quick-pill {
      background: #fff7ed;
      color: #b45309;
      border: 1px solid #fdba74;
      border-radius: 999px;
      padding: 10px 14px;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.2;
    }

    @media (max-width: 1100px) {
      .quick-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 720px) {
      .cp-quick-facts {
        padding: 0 16px;
      }

      .quick-card {
        padding: 22px;
      }
    }

    @media (max-width: 480px) {
      .quick-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="quick-card">
    <div class="quick-head">
      <h2>{data.title}</h2>
      {data.subtitle && <p>{data.subtitle}</p>}
    </div>

    <div class="quick-grid">
      {sharedItems.map((item) => (
        <div class="quick-item">
          <div class="quick-label">{item.label}</div>
          <div class="quick-value">
            {item.value}
            {item.subvalue && <span class="quick-subvalue">{item.subvalue}</span>}
          </div>
        </div>
      ))}
    </div>

    {pills.length > 0 && (
      <div class="quick-pills">
        {pills.map((pill) => (
          <span class="quick-pill">{pill}</span>
        ))}
      </div>
    )}
  </div>
</section>