---
const { data } = Astro.props;
const items = data.items ?? [];
---

<section class="cp-faq-v4" id="preguntas-frecuentes">
  <style>
    .cp-faq-v4 {
      width: 100%;
      max-width: 1180px;
      margin: 80px auto;
      padding: 0 20px;
      font-family: 'Segoe UI', Roboto, sans-serif !important;
      box-sizing: border-box;
    }

    .faq-head-v4 {
      text-align: center;
      margin-bottom: 40px;
    }

    .faq-head-v4 h2 {
      margin: 0 0 12px 0;
      color: #004A99;
      font-size: clamp(34px, 5vw, 56px);
      line-height: 1.1;
      font-weight: 900;
    }

    .faq-head-v4 p {
      margin: 0;
      color: #64748b;
      font-size: 18px;
      line-height: 1.45;
    }

    .faq-list-v4 {
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .faq-item-v4 {
      background: #ffffff;
      border-radius: 24px;
      border: 2px solid transparent;
      box-shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
      overflow: hidden;
      transition: border-color 0.25s ease, box-shadow 0.25s ease;
    }

    .faq-question-v4 {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 18px;
      padding: 28px 36px;
      cursor: pointer;
    }

    .faq-question-v4 h3 {
      margin: 0;
      color: #004A99;
      font-size: 20px;
      font-weight: 800;
      line-height: 1.25;
    }

    .faq-icon-v4 {
      flex: 0 0 auto;
      color: #004A99;
      font-size: 34px;
      line-height: 1;
      font-weight: 400;
      transition: transform 0.25s ease, color 0.25s ease;
    }

    .faq-answer-v4 {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      padding: 0 36px;
      transition: max-height 0.35s ease, opacity 0.25s ease, padding 0.25s ease;
    }

    .faq-answer-v4 p {
      margin: 0;
      color: #475569;
      font-size: 16px;
      line-height: 1.75;
      padding-bottom: 28px;
    }

    .faq-item-v4.active {
      border-color: #004A99;
      box-shadow: 0 14px 34px rgba(0, 74, 153, 0.10);
    }

    .faq-item-v4.active .faq-question-v4 {
      background: #004A99;
    }

    .faq-item-v4.active .faq-question-v4 h3 {
      color: #ffffff;
    }

    .faq-item-v4.active .faq-icon-v4 {
      color: #f2c94c;
      transform: rotate(45deg);
    }

    .faq-item-v4.active .faq-answer-v4 {
      max-height: 500px;
      opacity: 1;
      padding-top: 16px;
    }

    @media (max-width: 768px) {
      .cp-faq-v4 {
        margin: 60px auto;
        padding: 0 16px;
      }

      .faq-head-v4 h2 {
        font-size: 38px;
      }

      .faq-head-v4 p {
        font-size: 16px;
      }

      .faq-question-v4 {
        padding: 22px 22px;
      }

      .faq-question-v4 h3 {
        font-size: 18px;
      }

      .faq-answer-v4 {
        padding: 0 22px;
      }
    }
  </style>

  <div class="faq-head-v4">
    <h2>{data.title}</h2>
    {data.subtitle && <p>{data.subtitle}</p>}
  </div>

  <div class="faq-list-v4">
    {items.map((item, index) => (
      <div class={`faq-item-v4 ${index === 0 ? 'active' : ''}`}>
        <div class="faq-question-v4">
          <h3>{item.question}</h3>
          <span class="faq-icon-v4">+</span>
        </div>

        <div class="faq-answer-v4">
          <p>{item.answer || 'Respuesta pendiente por completar.'}</p>
        </div>
      </div>
    ))}
  </div>

  <script is:inline>
    (() => {
      const section = document.querySelector('#preguntas-frecuentes');
      if (!section) return;

      const triggers = section.querySelectorAll('.faq-question-v4');

      triggers.forEach((trigger) => {
        trigger.addEventListener('click', () => {
          const parent = trigger.parentElement;
          const allItems = section.querySelectorAll('.faq-item-v4');

          allItems.forEach((item) => {
            if (item !== parent) item.classList.remove('active');
          });

          parent.classList.toggle('active');
        });
      });
    })();
  </script>
</section>