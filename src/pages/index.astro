---
export const prerender = false;

import LandingLayout from '../layouts/LandingLayout.astro';
import CourseLandingTemplate from '../templates/CourseLandingTemplate.astro';
import { excelPresencialPage, excelPresencialSchema } from '../data/excel-presencial';
import { excelPresencialConfig } from '../data/excel-presencial-config';

let runtimeConfig = excelPresencialConfig;

try {
  const configUrl = new URL('/api/landing-config/excel-presencial', Astro.url);
  const response = await fetch(configUrl);

  if (response.ok) {
    runtimeConfig = await response.json();
  } else {
    console.warn('No se pudo cargar config remota. Se usa fallback local.', response.status);
  }
} catch (error) {
  console.warn('Error cargando config remota. Se usa fallback local.', error);
}
---

<LandingLayout
  title={excelPresencialPage.seo.title}
  description={excelPresencialPage.seo.description}
  canonical={excelPresencialPage.seo.canonical}
  gtmId={excelPresencialPage.gtmId}
  productId={excelPresencialPage.productId}
  schema={excelPresencialSchema}
>
<div style="padding:8px 12px;background:#fff3cd;color:#333;font-size:14px;border:1px solid #ffe69c;margin:12px 0;">
  debug configSource: {configSource}
  | offerings: {runtimeConfig.offerings?.length ?? 0}
  | published_at: {runtimeConfig.published_at}
  | error: {configError}
</div>

  <CourseLandingTemplate
    page={excelPresencialPage}
    config={runtimeConfig}
  />
</LandingLayout>